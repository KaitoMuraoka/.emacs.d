(use-package nov
  :mode ("\\.epub\\'" . nov-mode)

  :custom
  ;; プロポーショナルフォントで読みやすく表示する
  (nov-variable-pitch t)
  ;; 1行あたりの文字数（nil で自動折り返し）
  (nov-text-width 80))

(provide 'mk-nov)
